{
  "name": "zatca-lite",
  "version": "0.1.5",
  "description": "ZATCA Phase 2 onboarding, signing, QR, reporting, and clearance toolkit for Node.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "safdar-azeem",
  "repository": "https://github.com/safdar-azeem/zatca-lite",
  "files": [
    "dist",
    "README.md",
    "docs",
    "scripts"
  ],
  "license": "MIT",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "yarn clean && node -e \"require('child_process').execFileSync(process.execPath, [require.resolve('typescript/lib/tsc'), '-p', 'tsconfig.json'], { stdio: 'inherit' })\"",
    "prepare": "yarn build",
    "typecheck": "node -e \"require('child_process').execFileSync(process.execPath, [require.resolve('typescript/lib/tsc'), '-p', 'tsconfig.json', '--noEmit'], { stdio: 'inherit' })\"",
    "validate:official-sdk": "yarn build && node scripts/validate-official-sdk.js",
    "test": "vitest run",
    "release:patch": "yarn typecheck && yarn build && npm version patch --no-git-tag-version && npm publish --tag alpha"
  },
  "dependencies": {
    "@khaledhajsalem/zatca-node": "^1.0.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "endOfLine": "auto",
    "bracketSameLine": true
  }
}
